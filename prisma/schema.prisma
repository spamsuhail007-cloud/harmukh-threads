generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  category      String
  price         Int
  originalPrice Int?
  badge         String?
  badgeType     String?
  description   String      @db.Text
  specifications Json?
  productNote   String?   @db.Text
  images        String[]
  stock         Int         @default(0)
  isActive      Boolean     @default(true)
  reviews       Review[]
  orderItems    OrderItem[]
  stockNotifications StockNotification[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([category])
  @@index([slug])
}

model StockNotification {
  id        String   @id @default(cuid())
  email     String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([email, productId])
  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  author    String
  rating    Int
  text      String   @db.Text
  createdAt DateTime @default(now())
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  status          OrderStatus   @default(PENDING)
  items           OrderItem[]
  subtotal        Int
  shipping        Int           @default(0)
  total           Int
  firstName       String
  lastName        String
  email           String
  phone           String
  address         String
  city            String
  pincode         String
  country         String        @default("India")
  paymentMethod   String        @default("COD")
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  name      String
  image     String
  price     Int
  qty       Int
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String        @default("")
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@index([status])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum MessageStatus {
  NEW
  REPLIED
  RESOLVED
}
